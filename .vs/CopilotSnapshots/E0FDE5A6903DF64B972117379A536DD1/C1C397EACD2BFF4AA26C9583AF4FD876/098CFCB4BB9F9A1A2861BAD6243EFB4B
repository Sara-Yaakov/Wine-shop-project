using BlApi;
using BO;

namespace BlTest;

internal class Program
{
    private static readonly IBl s_bl = BlApi.Factory.Get();

    static void Main(string[] args)
    {
        try
        {
            Console.OutputEncoding = System.Text.Encoding.UTF8;

            if (args.Length > 0 && args[0].ToLower() == "autotest")
            {
                RunAutoTest();
                return;
            }

            MainMenu();
        }
        catch (Exception ex)
        {
            Console.ForegroundColor = ConsoleColor.Red;
            Console.WriteLine($"\nUnhandled error: {ex.Message}");
            Console.ResetColor();
        }
    }

    static void RunAutoTest()
    {
        Console.WriteLine("Starting automated BL tests...");
        try
        {
            // 1. Create product
            var prod = new Product
            {
                Id = 0,
                Name = "AutoTestWine",
                Category = Enums.Category.Wine,
                Color = "Red",
                ProductionDate = DateTime.Now.AddYears(-1),
                AgingPeriod = 1,
                Winery = "TestWinery",
                Description = "Auto test product",
                Season = Enums.Season.All,
                Amount = 10,
                Price = 100.0
            };
            int pid = s_bl.Product.AddProduct(prod);
            Console.WriteLine($"Created product id={pid}");

            // 2. Create customer
            var cust = new Customer { Id = 1, Name = "AutoCust", Address = "Addr", PhoneNumber = "000", IsClubMember = true };
            int cid = s_bl.Customer.AddCustomer(cust);
            Console.WriteLine($"Created customer id={cid}");

            // 3. Create sale: bundle of 3 units for price 250
            var sale = new Sale
            {
                Id = 0,
                ProductId = pid,
                RequiredAmount = 3,
                PriceAfterDiscount = 250,
                IsForClubMembersOnly = false,
                StartDate = DateTime.Now.AddDays(-1),
                EndDate = DateTime.Now.AddDays(1)
            };
            int sid = s_bl.Sale.AddSale(sale);
            Console.WriteLine($"Created sale id={sid} for product {pid}");

            // 4. Build order and add 4 units
            var order = new BO.Order { IsClubMember = true, Products = new List<ProductInOrder>(), TotalPrice = 0 };
            s_bl.Order.AddProductToOrder(order, pid, 4);
            Console.WriteLine($"Order after adding 4 units: amount={order.Products[0].Amount}, FinalPrice={order.Products[0].FinalPrice}");
            s_bl.Order.CalcTotalPrice(order);
            Console.WriteLine($"Order total: {order.TotalPrice}");

            double expected = 250 + 1 * 100; // one bundle (3) + 1 unit
            Console.WriteLine($"Expected product final price: {expected}");

            // Check correctness
            if (Math.Abs(order.Products[0].FinalPrice - expected) > 0.001)
                Console.WriteLine("ERROR: FinalPrice mismatch after initial add.");
            else
                Console.WriteLine("PASS: FinalPrice matches expected after initial add.");

            // 5. Decrease by 1 -> 3 units -> bundle price only
            s_bl.Order.AddProductToOrder(order, pid, -1);
            Console.WriteLine($"Order after decreasing 1: amount={(order.Products.Count>0?order.Products[0].Amount:0)}, FinalPrice={(order.Products.Count>0?order.Products[0].FinalPrice:0)}");
            s_bl.Order.CalcTotalPrice(order);
            Console.WriteLine($"Order total now: {order.TotalPrice}");

            double expected2 = 250; // exact bundle
            if (order.Products.Count==0 || Math.Abs(order.Products[0].FinalPrice - expected2) > 0.001)
                Console.WriteLine("ERROR: FinalPrice mismatch after decrease.");
            else
                Console.WriteLine("PASS: FinalPrice matches expected after decrease.");

            // 6. Finalize order
            s_bl.Order.DoOrder(order);
            var prodAfter = s_bl.Product.GetProductById(pid);
            Console.WriteLine($"Stock after DoOrder: {prodAfter.Amount}");
            int expectedStock = 10 - 3;
            if (prodAfter.Amount != expectedStock)
                Console.WriteLine("ERROR: Stock not reduced correctly after DoOrder.");
            else
                Console.WriteLine("PASS: Stock reduced correctly after DoOrder.");

            // 7. Edge case: try to add more than available
            var order2 = new BO.Order { IsClubMember = true, Products = new List<ProductInOrder>(), TotalPrice = 0 };
            try
            {
                s_bl.Order.AddProductToOrder(order2, pid, 1000);
                Console.WriteLine("ERROR: Expected exception when adding more than stock, but none thrown.");
            }
            catch (Exception ex)
            {
                Console.WriteLine($"PASS: Caught expected exception when adding too many: {ex.GetType().Name} - {ex.Message}");
            }

            // 8. Remove product by decreasing to zero
            var order3 = new BO.Order { IsClubMember = true, Products = new List<ProductInOrder>(), TotalPrice = 0 };
            s_bl.Order.AddProductToOrder(order3, pid, 2);
            s_bl.Order.AddProductToOrder(order3, pid, -2);
            Console.WriteLine($"Order3 products count after removing to zero: {order3.Products.Count} (expected 0)");

            Console.WriteLine("Automated BL tests finished.");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Automated test failed: {ex.GetType().Name} - {ex.Message}");
            Console.WriteLine(ex.StackTrace);
        }
    }

    // ─────────────────────────────────────────
    //  MAIN MENU
    // ─────────────────────────────────────────
    static void MainMenu()
    {
        while (true)
        {
            Console.Clear();
            Console.ForegroundColor = ConsoleColor.Cyan;
            Console.WriteLine("══════════════════════════════════");
            Console.WriteLine("         BL TEST - MAIN MENU      ");
            Console.WriteLine("══════════════════════════════════");
            Console.ResetColor();
            Console.WriteLine("1. Customers");
            Console.WriteLine("2. Products");
            Console.WriteLine("3. Sales");
            Console.WriteLine("4. Order (full flow)");
            Console.WriteLine("0. Exit");
            Console.Write("\nChoice: ");

            if (!int.TryParse(Console.ReadLine(), out int choice)) continue;
            switch (choice)
            {
                case 1: EntityMenu("Customer"); break;
                case 2: EntityMenu("Product"); break;
                case 3: EntityMenu("Sale"); break;
                case 4: OrderFlow(); break;
                case 0: return;
            }
        }
    }

    // ─────────────────────────────────────────
    //  GENERIC ENTITY SUB-MENU
    // ─────────────────────────────────────────
    static void EntityMenu(string entity)
    {
        while (true)
        {
            Console.Clear();
            Console.ForegroundColor = ConsoleColor.Yellow;
            Console.WriteLine($"══ {entity.ToUpper()} MENU ══");
            Console.ResetColor();
            Console.WriteLine("1. Create");
            Console.WriteLine("2. Read by ID");
            Console.WriteLine("3. Read by parameter");
            Console.WriteLine("4. Read all");
            Console.WriteLine("5. Update");
            Console.WriteLine("6. Delete");
            Console.WriteLine("0. Back");
            Console.Write("\nChoice: ");

            if (!int.TryParse(Console.ReadLine(), out int choice)) continue;
            if (choice == 0) return;

            try
            {
                switch (entity)
                {
                    case "Customer": CustomerAction(choice); break;
                    case "Product": ProductAction(choice); break;
                    case "Sale": SaleAction(choice); break;
                }
            }
            catch (Exception ex)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine($"\nError: {ex.Message}");
                Console.ResetColor();
                Pause();
            }
        }
    }

    // ─────────────────────────────────────────
    //  CUSTOMER ACTIONS
    // ─────────────────────────────────────────
    static void CustomerAction(int choice)
    {
        switch (choice)
        {
            case 1: // Create
                {
                    var c = ReadCustomerFromConsole();
                    int id = s_bl.Customer.AddCustomer(c);
                    Console.WriteLine($"\nCreated customer with ID: {id}");
                    Pause();
                    break;
                }
            case 2: // Read by ID
                {
                    int id = ReadInt("Enter customer ID: ");
                    var c = s_bl.Customer.GetCustomerById(id);
                    Console.WriteLine(c);
                    Pause();
                    break;
                }
            case 3: // Read by parameter — example: filter by club member
                {
                    Console.Write("Filter by club member? (true/false, or press Enter to skip): ");
                    string input = Console.ReadLine()!.Trim();
                    Customer result;
                    if (bool.TryParse(input, out bool isMember))
                        result = s_bl.Customer.GetCustomerByParameter(c => c.IsClubMember == isMember);
                    else
                        result = s_bl.Customer.GetCustomerByParameter(c => true);
                    Console.WriteLine(result);
                    Pause();
                    break;
                }
            case 4: // Read all
                {
                    var list = s_bl.Customer.GetAllCustomers();
                    PrintList(list);
                    Pause();
                    break;
                }
            case 5: // Update
                {
                    int id = ReadInt("Enter customer ID to update: ");
                    var existing = s_bl.Customer.GetCustomerById(id);
                    Console.WriteLine($"Existing: {existing}");
                    var updated = ReadCustomerFromConsole(id);
                    s_bl.Customer.UpdateCustomer(updated);
                    Console.WriteLine("Updated successfully.");
                    Pause();
                    break;
                }
            case 6: // Delete
                {
                    int id = ReadInt("Enter customer ID to delete: ");
                    s_bl.Customer.DeleteCustomer(id);
                    Console.WriteLine("Deleted successfully.");
                    Pause();
                    break;
                }
        }
    }

    static Customer ReadCustomerFromConsole(int existingId = -1)
    {
        int id = existingId >= 0 ? existingId : ReadInt("ID: ");
        Console.Write("Name: "); string name = Console.ReadLine()!;
        Console.Write("Address: "); string addr = Console.ReadLine()!;
        Console.Write("Phone: "); string phone = Console.ReadLine()!;
        Console.Write("Club member (true/false): ");
        bool.TryParse(Console.ReadLine(), out bool club);
        return new Customer { Id = id, Name = name, Address = addr, PhoneNumber = phone, IsClubMember = club };
    }

    // ─────────────────────────────────────────
    //  PRODUCT ACTIONS
    // ─────────────────────────────────────────
    static void ProductAction(int choice)
    {
        switch (choice)
        {
            case 1: // Create
                {
                    var p = ReadProductFromConsole();
                    int id = s_bl.Product.AddProduct(p);
                    Console.WriteLine($"\nCreated product with ID: {id}");
                    Pause();
                    break;
                }
            case 2: // Read by ID
                {
                    int id = ReadInt("Enter product ID: ");
                    var p = s_bl.Product.GetProductById(id);
                    Console.WriteLine(p);
                    Pause();
                    break;
                }
            case 3: // Read by parameter — example: filter by category
                {
                    Console.WriteLine("Filter by category (Wine/Beer/Champagne/Liqueur), or Enter to skip:");
                    Console.Write("> ");
                    string input = Console.ReadLine()!.Trim();
                    Product result;
                    if (Enum.TryParse<Enums.Category>(input, true, out var cat))
                        result = s_bl.Product.GetProductByParameter(p => p.Category == cat);
                    else
                        result = s_bl.Product.GetProductByParameter(p => true);
                    Console.WriteLine(result);
                    Pause();
                    break;
                }
            case 4: // Read all
                {
                    var list = s_bl.Product.GetAllProducts();
                    PrintList(list);
                    Pause();
                    break;
                }
            case 5: // Update
                {
                    int id = ReadInt("Enter product ID to update: ");
                    var existing = s_bl.Product.GetProductById(id);
                    Console.WriteLine($"Existing: {existing}");
                    var updated = ReadProductFromConsole(id);
                    s_bl.Product.UpdateProduct(updated);
                    Console.WriteLine("Updated successfully.");
                    Pause();
                    break;
                }
            case 6: // Delete
                {
                    int id = ReadInt("Enter product ID to delete: ");
                    // IProduct.DeleteProduct receives a Product object
                    var prod = s_bl.Product.GetProductById(id);
                    s_bl.Product.DeleteProduct(prod.Id);
                    Console.WriteLine("Deleted successfully.");
                    Pause();
                    break;
                }
        }
    }

    static Product ReadProductFromConsole(int existingId = -1)
    {
        int id = existingId >= 0 ? existingId : 0; // 0 → DAL assigns ID
        Console.Write("Name: "); string name = Console.ReadLine()!;
        Console.WriteLine("Category (Wine/Beer/Champagne/Liqueur):");
        Enum.TryParse<Enums.Category>(Console.ReadLine(), true, out var cat);
        Console.Write("Color: "); string color = Console.ReadLine()!;
        Console.Write("Production date (yyyy-MM-dd): ");
        DateTime.TryParse(Console.ReadLine(), out DateTime pd);
        int ap = ReadInt("Aging period (years): ");
        Console.Write("Winery: "); string winery = Console.ReadLine()!;
        Console.Write("Description: "); string desc = Console.ReadLine()!;
        Console.WriteLine("Season (Summer/Winter/Spring/Fall/All):");
        Enum.TryParse<Enums.Season>(Console.ReadLine(), true, out var seas);
        int amount = ReadInt("Amount in stock: ");
        double price = ReadDouble("Price: ");

        return new Product
        {
            Id = id,
            Name = name,
            Category = cat,
            Color = color,
            ProductionDate = pd,
            AgingPeriod = ap,
            Winery = winery,
            Description = desc,
            Season = seas,
            Amount = amount,
            Price = price
        };
    }

    // ─────────────────────────────────────────
    //  SALE ACTIONS
    // ─────────────────────────────────────────
    static void SaleAction(int choice)
    {
        switch (choice)
        {
            case 1: // Create
                {
                    var s = ReadSaleFromConsole();
                    int id = s_bl.Sale.AddSale(s);
                    Console.WriteLine($"\nCreated sale with ID: {id}");
                    Pause();
                    break;
                }
            case 2: // Read by ID
                {
                    int id = ReadInt("Enter sale ID: ");
                    var s = s_bl.Sale.GetSaleById(id);
                    Console.WriteLine(s);
                    Pause();
                    break;
                }
            case 3: // Read by parameter — filter by club-members-only
                {
                    Console.Write("Show only club-member sales? (true/false, or Enter to skip): ");
                    string input = Console.ReadLine()!.Trim();
                    Sale result;
                    if (bool.TryParse(input, out bool forClub))
                        result = s_bl.Sale.GetSaleByParameter(s => s.IsForClubMembersOnly == forClub);
                    else
                        result = s_bl.Sale.GetSaleByParameter(s => true);
                    Console.WriteLine(result);
                    Pause();
                    break;
                }
            case 4: // Read all
                {
                    var list = s_bl.Sale.GetAllSales();
                    PrintList(list);
                    Pause();
                    break;
                }
            case 5: // Update
                {
                    int id = ReadInt("Enter sale ID to update: ");
                    var existing = s_bl.Sale.GetSaleById(id);
                    Console.WriteLine($"Existing: {existing}");
                    var updated = ReadSaleFromConsole(id);
                    s_bl.Sale.UpdateSale(updated);
                    Console.WriteLine("Updated successfully.");
                    Pause();
                    break;
                }
            case 6: // Delete
                {
                    int id = ReadInt("Enter sale ID to delete: ");
                    s_bl.Sale.DeleteSale(id);
                    Console.WriteLine("Deleted successfully.");
                    Pause();
                    break;
                }
        }
    }

    static Sale ReadSaleFromConsole(int existingId = -1)
    {
        int id = existingId >= 0 ? existingId : 0;
        int productId = ReadInt("Product ID: ");
        int reqAmt = ReadInt("Required amount: ");
        int price = ReadInt("Price after discount: ");
        Console.Write("Club members only? (true/false): ");
        bool.TryParse(Console.ReadLine(), out bool club);
        Console.Write("Start date (yyyy-MM-dd): ");
        DateTime.TryParse(Console.ReadLine(), out DateTime start);
        Console.Write("End date (yyyy-MM-dd): ");
        DateTime.TryParse(Console.ReadLine(), out DateTime end);

        return new Sale
        {
            Id = id,
            ProductId = productId,
            RequiredAmount = reqAmt,
            PriceAfterDiscount = price,
            IsForClubMembersOnly = club,
            StartDate = start,
            EndDate = end
        };
    }

    // ─────────────────────────────────────────
    //  ORDER FULL FLOW
    // ─────────────────────────────────────────
    static void OrderFlow()
    {
        Console.Clear();
        Console.ForegroundColor = ConsoleColor.Green;
        Console.WriteLine("══ ORDER FLOW TEST ══");
        Console.ResetColor();

        // 1. Identify customer
        int customerId = ReadInt("Enter customer ID: ");
        Customer customer;
        try { customer = s_bl.Customer.GetCustomerById(customerId); }
        catch { Console.WriteLine("Customer not found."); Pause(); return; }

        Console.WriteLine($"Customer: {customer.Name}  | Club member: {customer.IsClubMember}");

        // 2. Build order
        BO.Order order = new BO.Order
        {
            IsClubMember = customer.IsClubMember,
            Products = new List<ProductInOrder>(),
            TotalPrice = 0
        };

        // 3. Add products in a loop
        while (true)
        {
            Console.WriteLine("\nCurrent order:");
            if (order.Products.Count == 0)
                Console.WriteLine("  (empty)");
            else
                foreach (var pio in order.Products)
                    Console.WriteLine($"  [{pio.ProductId}] {pio.ProductName} x{pio.Amount}  → final price: {pio.FinalPrice:F2}");

            Console.WriteLine("\n1. Add / change product amount");
            Console.WriteLine("2. Confirm order (DoOrder)");
            Console.WriteLine("0. Cancel");
            Console.Write("Choice: ");

            if (!int.TryParse(Console.ReadLine(), out int ch)) continue;
            if (ch == 0) return;
            if (ch == 2) break;

            if (ch == 1)
            {
                // Show available products
                Console.WriteLine("\nAvailable products:");
                foreach (var p in s_bl.Product.GetAllProducts())
                    Console.WriteLine($"  [{p.Id}] {p.Name}  stock:{p.Amount}  price:{p.Price:F2}");

                int pid = ReadInt("Product ID: ");
                int amount = ReadInt("Amount (negative to remove): ");

                try { s_bl.Order.AddProductToOrder(order, pid, amount); }
                catch (Exception ex)
                {
                    Console.ForegroundColor = ConsoleColor.Red;
                    Console.WriteLine($"Error: {ex.Message}");
                    Console.ResetColor();
                }
            }
        }

        // 4. Recalc total and display summary
        s_bl.Order.CalcTotalPrice(order);
        Console.WriteLine("\n══ ORDER SUMMARY ══");
        Console.WriteLine(order);

        // 5. Confirm and execute
        Console.Write("Confirm order? (yes/no): ");
        if (Console.ReadLine()?.Trim().ToLower() == "yes")
        {
            try
            {
                s_bl.Order.DoOrder(order);
                Console.ForegroundColor = ConsoleColor.Green;
                Console.WriteLine("Order completed successfully! Stock updated.");
                Console.ResetColor();
            }
            catch (Exception ex)
            {
                Console.ForegroundColor = ConsoleColor.Red;
                Console.WriteLine($"Order failed: {ex.Message}");
                Console.ResetColor();
            }
        }
        else
        {
            Console.WriteLine("Order cancelled.");
        }
        Pause();
    }

    // ─────────────────────────────────────────
    //  HELPERS
    // ─────────────────────────────────────────
    static int ReadInt(string prompt)
    {
        int result;
        do { Console.Write(prompt); } while (!int.TryParse(Console.ReadLine(), out result));
        return result;
    }

    static double ReadDouble(string prompt)
    {
        double result;
        do { Console.Write(prompt); } while (!double.TryParse(Console.ReadLine(), out result));
        return result;
    }

    static void PrintList<T>(List<T> list)
    {
        if (list.Count == 0) { Console.WriteLine("(empty list)"); return; }
        int i = 1;
        foreach (var item in list)
            Console.WriteLine($"── {i++} ──\n{item}");
    }

    static void Pause()
    {
        Console.WriteLine("\nPress any key to continue...");
        Console.ReadKey(true);
    }
}